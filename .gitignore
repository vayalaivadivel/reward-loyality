# ------------------------------
# Terraform
# ------------------------------

# Local .terraform directory
.terraform/

# Terraform state files (VERY IMPORTANT)
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
!infra/environments/*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (OPTIONAL)
# Keep it if you want consistent provider versions
# .terraform.lock.hcl

# CLI config
.terraformrc
terraform.rc

# ------------------------------
# Environment specific overrides
# ------------------------------
.env
.env.*

# ------------------------------
# OS / Editor files
# ------------------------------
.DS_Store
Thumbs.db

# VS Code
.vscode/

# IntelliJ / JetBrains
.idea/

# ------------------------------
# Logs
# ------------------------------
*.log

# ------------------------------
# Python (if used)
# ------------------------------
__pycache__/
*.pyc

# ------------------------------
# Node (if any frontend/tools)
# ------------------------------
node_modules/

# ------------------------------
# Secrets / credentials
# ------------------------------
*.pem
*.key
*.crt

# AWS credentials (extra safety)
.aws/

# ------------------------------
# Misc
# ------------------------------
*.bak
*.tmp

# Terraform
.terraform/
*.tfstate
*.tfstate.backup

# Lambda build artifacts
*.zip

